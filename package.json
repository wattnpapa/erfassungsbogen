{
  "name": "erfassungsbogen",
  "version": "1.0.0",
  "description": "Digitaler Einheiten-Erfassungsbogen für BOS: Assistent, PDF-Export im Papier-Layout, Offline-Transport per QR-Code.",
  "main": "electron/main.js",
  "scripts": {
    "demo": "tsx scripts/qr-demo.ts",
    "beispiele": "node --import tsx scripts/beispielboegen-pdf.mts",
    "icons": "node scripts/render-icons.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cross-env NODE_OPTIONS=\"--import tsx\" cucumber-js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ios:sync": "vite build && cap sync ios",
    "ios:open": "cap open ios",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "keywords": [],
  "author": {
    "name": "Johannes Rudolph",
    "email": "johannes.rudolph@thw-oldenburg.de"
  },
  "license": "EUPL-1.2",
  "build": {
    "appId": "de.erfassungsbogen.app",
    "productName": "Erfassungsbogen",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "createStartMenuShortcut": true,
      "createDesktopShortcut": true,
      "shortcutName": "Erfassungsbogen",
      "menuCategory": "Sonstige"
    },
    "linux": {
      "target": [
        "deb",
        "pacman"
      ],
      "category": "Utility",
      "desktop": {
        "Name": "Erfassungsbogen",
        "Categories": "Utility;"
      }
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/wattnpapa/erfassungsbogen/releases/latest/download"
      }
    ],
    "generateUpdatesFilesForAllChannels": true
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/barcode-scanner": "^3.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/share": "^8.0.1",
    "electron-updater": "^6.8.3",
    "jsqr": "^1.4.0",
    "pako": "^3.0.1",
    "pdfmake": "^0.3.11",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "taktische-zeichen-core": "^0.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@cucumber/cucumber": "^12.9.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.1",
    "@types/pako": "^2.0.4",
    "@types/pdfmake": "^0.3.3",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wait-on": "^8.0.2",
    "workbox-window": "^7.4.1"
  },
  "type": "module",
  "private": true
}
